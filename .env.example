# Copy this file to .env and fill in values as you set up each service.
# cp .env.example .env
#
# Start with just the EC2 / game server vars.
# Add Redis, DynamoDB, S3 etc. as you build each component.

# ── EC2 Game Server (needed from day 1) ─────────────────────────────────────
AWS_REGION=eu-west-2
SERVER_HOST=0.0.0.0
SERVER_UDP_PORT=9000
SERVER_WS_PORT=8080
TICK_RATE=20
MAX_PLAYERS=2

# ── Redis / ElastiCache (needed when T4 Redis Writer is implemented) ─────────
# Copy the primary endpoint from the AWS ElastiCache console.
# REDIS_HOST=your-cluster.abc123.euw2.cache.amazonaws.com
# REDIS_PORT=6379

# ── DynamoDB (needed when sidecar is implemented) ────────────────────────────
# DYNAMODB_TABLE=fpga-raycaster

# ── S3 (needed after DynamoDB is working) ────────────────────────────────────
# S3_BUCKET=fpga-raycaster-data

# ── SNS + Lambda (needed after S3 is working) ────────────────────────────────
# SNS_TOPIC_ARN=arn:aws:sns:eu-west-2:YOUR_ACCOUNT_ID:fpga-raycaster-game-end

# ── Deployment ───────────────────────────────────────────────────────────────
# EC2_HOST=ubuntu@your-elastic-ip
# EC2_KEY=~/.ssh/fpga-raycaster.pem
